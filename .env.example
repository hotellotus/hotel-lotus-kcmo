# ── Required ──────────────────────────────────────────────────────────────────

# MySQL connection string (Railway provides this automatically as ${{MySQL.DATABASE_URL}})
DATABASE_URL=mysql://user:password@host:3306/dbname

# Secret used to sign admin session JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string

# Password to log in to the /admin dashboard
ADMIN_PASSWORD=choose_a_strong_password

# ── Email (optional — needed for contact form) ─────────────────────────────────

# Gmail address used to send contact form emails
GMAIL_USER=your@gmail.com

# Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_PASSWORD=your_gmail_app_password

# ── Server ─────────────────────────────────────────────────────────────────────

# Railway sets this automatically; leave unset for local dev (defaults to 3000)
PORT=3000
NODE_ENV=production
